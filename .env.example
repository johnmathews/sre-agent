# LLM Provider: "openai" (default) or "anthropic"
# When using anthropic, set ANTHROPIC_API_KEY (from `claude setup-token`)
# When using openai, set OPENAI_API_KEY
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible proxy (optional — leave empty to use OpenAI directly)
# For claude-max-api-proxy: http://localhost:3456/v1
# When using a proxy, OPENAI_API_KEY can be set to any placeholder value
OPENAI_BASE_URL=

# Anthropic API (optional — only needed when LLM_PROVIDER=anthropic)
# The Anthropic path uses the Claude Agent SDK, which runs the Claude Code CLI
# as a subprocess. Auth is handled automatically via mounted ~/.claude/ credentials.
#
# Setup:
#   1. Install Claude Code: npm install -g @anthropic-ai/claude-code
#   2. Authenticate: claude login   (or claude setup-token for headless)
#   3. Credentials are stored in ~/.claude/ and mounted into Docker via CLAUDE_CONFIG_DIR
#
# ANTHROPIC_API_KEY is not used directly by the SDK path — auth comes from
# the mounted credentials. Set it to satisfy the config validator:
ANTHROPIC_API_KEY=sk-ant-oat01-placeholder
ANTHROPIC_MODEL=claude-opus-4-6

# Path to Claude Code credentials directory (mounted read-only into Docker)
# Default: ~/.claude (where `claude login` stores OAuth tokens)
CLAUDE_CONFIG_DIR=~/.claude

# Prometheus
PROMETHEUS_URL=http://prometheus.example.com:9090

# Grafana (alerting)
GRAFANA_URL=http://grafana.example.com:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_...

# Proxmox VE API (optional — leave empty to disable PVE tools)
PROXMOX_URL=https://proxmox.example.com:8006
PROXMOX_API_TOKEN=api@pam!tokenname=secret-token-value
PROXMOX_VERIFY_SSL=false
PROXMOX_CA_CERT=
PROXMOX_NODE=proxmox

# Proxmox Backup Server API (optional — leave empty to disable PBS tools)
PBS_URL=https://pbs.example.com:8007
PBS_API_TOKEN=user@pbs!tokenname:secret-token-value
PBS_VERIFY_SSL=false
PBS_CA_CERT=
PBS_NODE=localhost
PBS_DEFAULT_DATASTORE=backups

# TrueNAS SCALE API (optional — leave empty to disable TrueNAS tools)
TRUENAS_URL=https://truenas.example.com
TRUENAS_API_KEY=1-ABcDeFgHiJkLmNoPqRsTuVwXyZ
TRUENAS_VERIFY_SSL=false
TRUENAS_CA_CERT=

# Loki API (optional — leave empty to disable Loki log tools)
LOKI_URL=http://loki.example.com:3100

# Agent memory store (optional — leave empty to disable persistent memory)
# SQLite database for report archive, incident journal, and metric baselines
MEMORY_DB_PATH=/app/memory.db

# Extra document directories for RAG ingestion (comma-separated absolute paths)
# These directories are read-only — only .md files are loaded for embeddings
EXTRA_DOCS_DIRS=

# Conversation history — host path bind-mounted to /app/conversations in Docker
CONVERSATION_HISTORY_HOST_DIR=./conversations

# SMTP / Email (optional — leave empty to disable email delivery of reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
REPORT_RECIPIENT_EMAIL=your-email@gmail.com

# Report schedule (optional — leave empty to disable scheduled reports)
# Cron expression: minute hour day-of-month month day-of-week
REPORT_SCHEDULE_CRON=0 8 * * 1
REPORT_LOOKBACK_DAYS=7

# Documentation MCP server (optional — leave empty to disable)
# Provides semantic search over indexed git repos (disk-status-exporter, etc.)
# SDK/Anthropic path only. Internal Docker URL: http://documentation-server:8080/mcp
DOCUMENTATION_MCP_URL=

# MCP Server auth token (optional — leave empty to disable MCP endpoint)
# When set, exposes SRE tools as a Streamable HTTP MCP server at /mcp
# Clients (Claude Code, Claude Desktop) authenticate with this as a Bearer token
# Example: claude mcp add --transport http sre-agent --header "Authorization: Bearer <token>" http://localhost:8000/mcp
SRE_AGENT_MCP_AUTH_TOKEN=

# Request timeout for the /ask endpoint in seconds (default: 120)
# Requests exceeding this limit return HTTP 504 Gateway Timeout.
# Set to 0 to disable the timeout (not recommended in production).
REQUEST_TIMEOUT_SECONDS=120

# Docker deployment — external port for the API (default: 8000)
# Only affects host-side port mapping; internal container communication is unaffected
SRE_API_PORT=8000

# Docker deployment — external port for the webapp frontend (default: 8080)
# The webapp container reaches the API via the internal docker network.
SRE_WEBAPP_PORT=8080
